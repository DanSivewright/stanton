# MongoDB Atlas replica set (required for Payload transactions).
# Atlas → Connect → Drivers → copy connection string, replace <password>, set db name.
# Example: mongodb+srv://USER:PASSWORD@cluster.mongodb.net/stanton?retryWrites=true&w=majority
DATABASE_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/stanton?retryWrites=true&w=majority

# Generate: openssl rand -hex 32
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Vercel Cron auth — only needed when vercel.json crons are enabled (Pro plan).
# Copy vercel.cron.example.json → vercel.json, then set in Vercel env (Preview + Production).
# Generate: openssl rand -hex 16
# CRON_SECRET=YOUR_CRON_SECRET_HERE

# Local dev only: enable in-process job runner (do not set on Vercel).
# ENABLE_PAYLOAD_AUTORUN=true
